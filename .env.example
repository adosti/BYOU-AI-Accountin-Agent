# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth / Gateway ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# ── BYou Platform login ─────────────────────────────────────
# Credentials for the single-business login screen.
# Change these before deploying!
BYOU_USERNAME=byou
BYOU_PASSWORD=byou123

# ── Expense Tracker DB ──────────────────────────────────────
# SQLite file created automatically on first run.
# Use an absolute path to store outside the project directory.
DB_PATH=tracker.db

# ── Google Drive MCP ───────────────────────────────────────
# Run the Google Drive MCP server as a local process:
#   npx @google-labs/google-drive-mcp
# Obtain credentials from console.cloud.google.com → OAuth2 client (Desktop app)
# Scopes required: https://www.googleapis.com/auth/drive.file
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_RECEIPTS_FOLDER_ID=root   # Drive folder ID for receipt storage

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
